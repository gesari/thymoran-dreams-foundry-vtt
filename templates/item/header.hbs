{{! Item Sheet Header }}
<header class="sheet-header">
    <img 
        class="profile-img"
        src="{{item.img}}"
        data-edit="img"
        data-action="onEditImage"
        data-tooltip="{{item.name}}"
    />
    <div class="header-fields">
        <div class="document-name">
            <input 
                name="name"
                type="text"
                value="{{item.name}}"
                placeholder="Name"
            />
        </div>

        {{#if (eq item.type 'gear')}}
            <div class="grid grid-1col">
                <div class="resource">
                    <label class="resource-label">{{localize 'THYMORANDREAMS.Item.Gear.FIELDS.quantity.label'}}</label>
                    <input 
                        type="text"
                        name="system.quantity"
                        value="{{system.quantity}}"
                        data-dtype="Number"
                    />
                </div>
            </div>
        {{/if}}
    </div>
</header>